# ===========================================
# Autozap Python Agent - Environment Variables
# ===========================================

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI Provider (Gemini or OpenAI-compatible)# AI Provider (OPTIONAL - normally sent by Edge Function per request)
# Only needed for local development / testing
# AI_API_KEY=your_google_api_key_here
# AI_API_URL=https://generativelanguage.googleapis.com/v1beta
# AI_MODEL=gemini-2.0-flash

# --- LangSmith (Monitoring) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_sk_your_key_here
LANGCHAIN_PROJECT=autozap-agent

# --- Agent Service ---
AGENT_SECRET=your-shared-secret-between-edge-function-and-agent
PORT=8000
